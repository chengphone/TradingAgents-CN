.module-tabs { margin-bottom: 24rpx; }
.tab-scroll { white-space: nowrap; }
.tab-item { display: inline-block; padding: 12rpx 24rpx; margin-right: 12rpx; border-radius: 8rpx; font-size: 26rpx; background: var(--bg-input); color: var(--text-secondary); }
.tab-active { background: var(--primary); color: #000; }
