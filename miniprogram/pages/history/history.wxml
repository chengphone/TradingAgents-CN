<!-- 历史报告列表 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="input search-input"
      placeholder="搜索股票代码 (如 000001)"
      value="{{searchCode}}"
      bindinput="onSearchInput"
      bindconfirm="doSearch"
    />
    <button class="btn btn-primary search-btn" bindtap="doSearch" size="min">搜索</button>
  </view>

  <!-- 列表 -->
  <view wx:if="{{reports.length > 0}}">
    <report-card
      wx:for="{{reports}}"
      wx:key="analysis_id"
      data="{{item}}"
      bindtap="goDetail"
      data-id="{{item.analysis_id}}"
    />
  </view>

  <view wx:elif="{{!loading}}" class="empty">
    <text class="empty-icon">📄</text>
    <text class="empty-text">暂无分析记录</text>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && reports.length > 0}}" class="load-more" bindtap="loadMore">
    <text>{{loadingMore ? '加载中...' : '加载更多'}}</text>
  </view>
</view>
