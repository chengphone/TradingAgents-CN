.rc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.rc-left { display: flex; align-items: baseline; gap: 12rpx; }
.rc-symbol { font-size: 32rpx; font-weight: 600; }
.rc-name { font-size: 26rpx; color: #888; }
.rc-summary { font-size: 26rpx; color: #ccc; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.rc-footer { display: flex; justify-content: space-between; margin-top: 12rpx; }
.rc-time { font-size: 22rpx; color: #666; }
.rc-confidence { font-size: 22rpx; color: var(--primary); }
