# ============================================
# TradingAgents-CN 微信小程序 · 云托管环境变量
# ============================================

# ---- 云开发 ----
CLOUDBASE_ENV_ID=your-env-id
CLOUDBASE_API_KEY=your-api-key

# ---- 微信小程序 ----
WECHAT_APPID=wx1234567890
WECHAT_SECRET=abc123def4567890abcdef1234567890
WECHAT_DAILY_QUOTA=10

# ---- MongoDB (tradingagents 引擎内部使用) ----
# 云托管环境无法使用本地 MongoDB，可连接 MongoDB Atlas 免费集群
# 或使用云数据库 HTTP API 完全替代（需后续适配）
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=tradingagents_cn
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE_NAME=tradingagents_cn
USE_MONGODB_STORAGE=false

# ---- LLM API Keys ----
DASHSCOPE_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx
OPENAI_API_KEY=sk-xxx
AI302_API_KEY=
AIHUBMIX_API_KEY=

# ---- 数据源 ----
TUSHARE_TOKEN=
FINNHUB_API_KEY=

# ---- 默认模型 ----
TRADINGAGENTS_QUICK_MODEL=qwen3.6-plus
TRADINGAGENTS_DEEP_MODEL=DEEPSEEK-V4-PRO

# ---- JWT ----
JWT_SECRET=change-this-to-a-random-64-character-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ---- 服务配置 ----
HOST=0.0.0.0
PORT=8000
DEBUG=false
TIMEZONE=Asia/Shanghai

# ---- Redis (可选，已移除) ----
REDIS_ENABLED=false
